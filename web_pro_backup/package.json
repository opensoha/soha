{
  "name": "ant-design-pro",
  "version": "6.0.0",
  "private": true,
  "description": "An out-of-box UI solution for enterprise applications",
  "repository": "git@github.com:ant-design/ant-design-pro.git",
  "scripts": {
    "analyze": "cross-env ANALYZE=1 max build",
    "build": "max build",
    "deploy": "cross-env CI=true max build && gh-pages -d dist",
    "dev": "cross-env UMI_ENV=dev MOCK=none max dev",
    "i18n-remove": "max i18n-remove --locale=zh-CN --write",
    "lint": "npm run biome:lint && npm run tsc",
    "lint-staged": "lint-staged",
    "biome:lint": "biome lint",
    "biome": "biome check --write",
    "openapi": "max openapi",
    "prepare": "max setup",
    "preview": "max preview --port 8000",
    "preview:build": "max build && max preview --port 8000",
    "record": "cross-env NODE_ENV=development UMI_ENV=test max record --scene=login",
    "start": "cross-env UMI_ENV=dev max dev",
    "start:no-mock": "cross-env MOCK=none max dev",
    "start:pre": "cross-env UMI_ENV=pre MOCK=none max dev",
    "start:test": "cross-env UMI_ENV=test MOCK=none max dev",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:update": "jest -u",
    "tsc": "tsc --noEmit"
  },
  "browserslist": [
    "defaults"
  ],
  "dependencies": {
    "@ant-design/charts": "^2.6.5",
    "@ant-design/icons": "^6.0.1",
    "@ant-design/pro-components": "^3.1.12-0",
    "@ant-design/x": "^2.1.3",
    "@antv/g6": "^5.0.49",
    "@monaco-editor/react": "^4.7.0",
    "@tailwindcss/vite": "^4.1.5",
    "@tanstack/react-query": "^5.75.7",
    "@types/node": "^25.6.0",
    "@umijs/max": "^4.6.49",
    "@visactor/react-vchart": "^2.0.22",
    "@visactor/vchart": "^2.0.22",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "@xyflow/react": "^12.10.2",
    "antd": "^6.0.0",
    "antd-style": "^4.1.0",
    "axios": "^1.9.0",
    "cross-env": "^10.1.0",
    "dagre": "^0.8.5",
    "dayjs": "^1.11.13",
    "monaco-editor": "^0.55.1",
    "monaco-yaml": "^5.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.0",
    "react-window": "^2.2.7",
    "zod": "^3.24.4",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "@types/dagre": "^0.7.54",
    "@types/react": "^18.3.20",
    "@types/react-dom": "^18.3.6",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^26.1.0",
    "tailwindcss": "^4.1.5",
    "typescript": "^5.8.2",
    "vite": "^6.2.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "create-umi": {
    "ignoreScript": [
      "docker*",
      "functions*",
      "site",
      "generateMock"
    ],
    "ignoreDependencies": [
      "netlify*",
      "serverless"
    ],
    "ignore": [
      ".dockerignore",
      ".git",
      ".github",
      ".gitpod.yml",
      "CODE_OF_CONDUCT.md",
      "Dockerfile",
      "Dockerfile.*",
      "lambda",
      "LICENSE",
      "netlify.toml",
      "README.*.md",
      "azure-pipelines.yml",
      "docker",
      "CNAME",
      "create-umi"
    ]
  }
}
